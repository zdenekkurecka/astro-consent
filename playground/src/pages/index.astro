---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Cookie Consent Playground">
  <h1>Cookie Consent Playground</h1>
  <p>
    This page demonstrates the <code>@zdenekkurecka/astro-consent</code> integration.
    The consent banner should appear on first visit.
  </p>

  <h2>Theming</h2>
  <p>
    This playground overrides <code>--cc-primary</code> to orange from the
    site's global stylesheet. Click <em>Show Banner</em> below to see it:
  </p>
  <pre>{`:root {
  --cc-primary: #ea580c;
  --cc-primary-hover: #c2410c;
}`}</pre>

  <h2>Runtime API Controls</h2>
  <div class="controls">
    <button id="btn-show">Show Banner</button>
    <button id="btn-prefs">Show Preferences</button>
    <button id="btn-reset">Reset Consent</button>
    <button id="btn-get">Get State</button>
  </div>

  <h2>Current State</h2>
  <pre id="state">No consent data yet.</pre>

  <script is:inline>
    // Harness hook (#80): echo URL params onto <html data-cc-test-*> so
    // Playwright fixtures (see `playground/e2e/helpers.ts` → `openBanner`)
    // can parameterize the page without a build rebuild. Params currently
    // recognized: layout, categoriesOnBanner, showCounter, equalWeight.
    // Feature PRs (#39, #44, #77, #79) read these attrs to flip variants;
    // before those land the attrs are inert and specs can `test.fixme()`.
    (function () {
      const params = new URLSearchParams(window.location.search);
      const known = ['layout', 'categoriesOnBanner', 'showCounter', 'equalWeight'];
      for (const key of known) {
        const value = params.get(key);
        if (value === null) continue;
        const attr = 'data-cc-test-' + key.replace(/([A-Z])/g, '-$1').toLowerCase();
        document.documentElement.setAttribute(attr, value);
      }
    })();
  </script>

  <script>
    function refreshState() {
      const el = document.getElementById('state');
      const consent = window.astroConsent;
      if (el && consent) {
        const state = consent.get();
        el.textContent = state ? JSON.stringify(state, null, 2) : 'No consent data yet.';
      }
    }

    // Subscribe to consent events. Unlike `.toString()`-serialized callbacks,
    // these listeners run in the page's normal module scope and can close
    // over imports, outer variables, etc.
    document.addEventListener('astro-consent:consent', (e) => {
      console.log('[playground] Consent given:', e.detail);
      refreshState();
    });
    document.addEventListener('astro-consent:change', (e) => {
      console.log('[playground] Consent changed:', e.detail);
      refreshState();
    });

    document.addEventListener('astro:page-load', () => {
      refreshState();

      document.getElementById('btn-show')?.addEventListener('click', () => {
        window.astroConsent?.show();
      });

      document.getElementById('btn-prefs')?.addEventListener('click', () => {
        window.astroConsent?.showPreferences();
      });

      document.getElementById('btn-reset')?.addEventListener('click', () => {
        window.astroConsent?.reset();
        refreshState();
      });

      document.getElementById('btn-get')?.addEventListener('click', () => {
        refreshState();
      });
    });
  </script>
</Layout>
